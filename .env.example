# ─────────────────────────────────────────────────────────────────────────────
# FlipBot Pro — Environment Configuration
# Copy this file:  cp .env.example .env
# Then fill in each value below. Never commit your .env file.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000

# ── eBay Developer API ────────────────────────────────────────────────────────
# Register at: https://developer.ebay.com/my/keys
# Create a "Production" keyset for live listings, "Sandbox" for testing
EBAY_APP_ID=YourApp-FlipBot-PRD-xxxxxxxxxxx-xxxxxxxx
EBAY_CERT_ID=PRD-xxxxxxxxxxxxxxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
EBAY_DEV_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
EBAY_REDIRECT_URI=YourApp-FlipBot-PRD-xxxxxxxx   # From eBay app settings
EBAY_SANDBOX=false                                # true = test mode, no real listings

# ── OpenAI API ────────────────────────────────────────────────────────────────
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...

# ── Facebook Marketplace ──────────────────────────────────────────────────────
# Location code: use the city slug from marketplace URL (e.g., "dallas", "los-angeles")
FB_LOCATION=dallas
FB_MAX_PRICE=5000
FB_HEADLESS=true          # false = watch the browser run (useful for debugging)

# ── Bot Scan Behaviour ────────────────────────────────────────────────────────
BOT_SCAN_INTERVAL_SEC=300          # Seconds between full marketplace scans (default 5 min)
BOT_MIN_MARGIN_PCT=25              # Flag as match only if margin is >= this %
BOT_MAX_DAILY_MESSAGES=200        # Hard cap on outgoing lowball messages per day
BOT_KEYWORDS=bike,ebike,tools,drill,vacuum,mixer,motorcycle,playstation,macbook,iphone

# ── Proxy (optional but recommended at high volume) ───────────────────────────
# Format: http://username:password@host:port
PROXY_URL=
